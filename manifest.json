{
  "manifest_version": 3,
  "name": "Instahyre Auto Apply",
  "version": "1.0",
  "description": "Auto apply jobs on Instahyre",

  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*.instahyre.com/*"],

  "icons": {
    "16": "icons/icon-1.png",
    "48": "icons/icon-1.png",
    "128": "icons/icon-1.png"
  },

  "content_scripts": [
    {
      "matches": ["https://*.instahyre.com/*"],
      "js": ["content/content.js"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-1.png",
      "48": "icons/icon-1.png"
    }
  }
}